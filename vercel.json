{
	"version": 2,
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/api"
		}
	],
	"builds": [
		{
			"src": "api/index.ts",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/(.*)",
			"dest": "/api/index.ts",
			"methods": [
				"GET",
				"POST",
				"PUT",
				"PATCH",
				"DELETE",
				"OPTIONS"
			]
		}
	]
}