{
    "compilerOptions": {
        "module": "NodeNext",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2020",
        "noImplicitAny": false,
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./",
        "strict": false,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "*": [
                "node_modules/*"
            ]
        }
    },
    "include": ["api/**/*.ts", "src/**/*.ts"],
    "exclude": ["node_modules"]
}